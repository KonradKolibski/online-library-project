VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# AI book-recommendation chat (Discover tab) — Grok / xAI.
# XAI_API_KEY is NOT a frontend var. It is a Supabase Edge Function secret and
# must never be prefixed with VITE_ (that would leak it into the browser bundle).
# Set it on the server only:
#   supabase secrets set XAI_API_KEY=xai-...
# Optionally override the model (defaults to grok-4.3):
#   supabase secrets set XAI_MODEL=grok-4.3

# Reading challenges (Strapi headless CMS on Railway).
# The `challenges` edge function reads challenge definitions from Strapi
# server-side, so these are Supabase Edge Function secrets — NEVER prefixed with
# VITE_ (the read token must not reach the browser). Set them on the server only:
#   supabase secrets set STRAPI_URL=https://<your-app>.up.railway.app
#   supabase secrets set STRAPI_API_TOKEN=<read-only API token from Strapi admin>
# If STRAPI_URL is unset the app simply shows no challenges (graceful no-op).
