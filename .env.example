VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# AI book-recommendation chat (Discover tab) — Grok / xAI.
# XAI_API_KEY is NOT a frontend var. It is a Supabase Edge Function secret and
# must never be prefixed with VITE_ (that would leak it into the browser bundle).
# Set it on the server only:
#   supabase secrets set XAI_API_KEY=xai-...
# Optionally override the model (defaults to grok-4.3):
#   supabase secrets set XAI_MODEL=grok-4.3
